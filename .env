# ─────────────────────────────────────────────────────────────
#  NeuroVirus Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── VirusTotal API Key ────────────────────────────────────────
# Get a free key at https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/min, 500 requests/day
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Flask Secret Key ──────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=change_me_to_a_long_random_string_in_production

# ── ClamAV Connection ─────────────────────────────────────────
# When using Docker Compose, keep these defaults
# When running locally, use 127.0.0.1
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310

# ── Scan Settings ─────────────────────────────────────────────
# Shannon entropy threshold (7.0 = flag as possibly packed/encrypted)
ENTROPY_THRESHOLD=7.0

# Max file size to upload to VirusTotal (bytes). Free tier = 32MB
MAX_FILE_SIZE_VIRUSTOTAL=33554432
